# ─────────────────────────────────────────────────────────────────────────────
# Excluded from the published "main website" repo
# ─────────────────────────────────────────────────────────────────────────────
# Admin / standalone tools — operational utilities that aren't part of the
# marketing site bundle. They live in this working tree for the team to use
# locally; they don't need to ship with the Next.js codebase.
tools/
dashboard/

# Google Ads MCP server — standalone Python harness for managing Google Ads.
# Contains live API credentials (google-ads.yaml, .env). Operational tooling,
# never part of the website bundle, and MUST NOT be pushed. The folder also
# has its own .gitignore as a second layer protecting just the secrets.
google-ads-mcp/

# Early-stage design concepts — one-off HTML mockups that informed the build.
# Useful local reference, not part of the live site.
concepts/

# Claude Code workspace (project skill + local launch config). Local dev
# tooling, not website code.
.claude/

# Competitor / current-site research scripts — used once during discovery,
# not needed by the website build.
crawl_sites.py
scrape_images.py
scraped-images-run.log
