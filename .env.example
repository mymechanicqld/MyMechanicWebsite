# ─────────────────────────────────────────────────────────────────────────────
# My Mechanic QLD — environment variable template
# Copy to `.env.local` for local dev. In production, set these in the Vercel
# project settings (Settings → Environment Variables). Anything prefixed with
# NEXT_PUBLIC_ is exposed to the browser bundle; everything else stays
# server-only.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (database for quote_submissions)
NEXT_PUBLIC_SUPABASE_URL=https://depduvjclelykqcnhlsm.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_cgK1KYRlLrYrn1YjhQTVcg_hSJzcOxr

# Resend (transactional email for quote-request notifications)
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx

# Address that receives quote-request notifications
QUOTE_RECIPIENT_EMAIL=mymechanicqld@gmail.com

# From-address for outbound transactional email. The mymechanicqld.com.au
# domain is verified in Resend (DKIM + SPF), so we send from it. The code wraps
# this with the customer's name, e.g. "Jane Doe via My Mechanic QLD <this@addr>".
QUOTE_SENDER_EMAIL=bookings@mymechanicqld.com.au

# Google Analytics 4 — Measurement ID from analytics.google.com
# Admin → Data Streams → Web → Measurement ID (starts with G-)
# Already hard-coded as a fallback in app/layout.tsx so the tag fires
# in production even if this var is empty. Setting it here just removes
# the hard-coded value from the picture.
NEXT_PUBLIC_GA_ID=G-6YSECEQTDG

# Google Ads — conversion-tracking tag (starts with AW-). Runs off the
# same gtag.js instance as GA4. Also hard-coded as a fallback in
# app/layout.tsx. This is the account's REAL conversion-tracking ID
# (the old AW-17575487896 held no conversion actions, so nothing recorded —
# see google-ads-mcp/audit/04-conversion-tracking.md).
NEXT_PUBLIC_GOOGLE_ADS_ID=AW-17735133165

# Google Ads conversion-action "send_to" labels (used by lib/gtag.ts).
NEXT_PUBLIC_ADS_FORM_LABEL=AW-17735133165/NlXGCJmBjcEbEO3P4ohC
NEXT_PUBLIC_ADS_CALL_LABEL=AW-17735133165/uMnkCMq1nbkcEO3P4ohC

# Google Search Console — value of the meta-tag verification (just the
# content="..." string, not the full tag).
NEXT_PUBLIC_GSC_VERIFICATION=
