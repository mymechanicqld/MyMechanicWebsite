# ─────────────────────────────────────────────────────────────────────────────
# My Mechanic QLD — environment variable template
# Copy to `.env.local` for local dev. In production, set these in the Vercel
# project settings (Settings → Environment Variables). Anything prefixed with
# NEXT_PUBLIC_ is exposed to the browser bundle; everything else stays
# server-only.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (database for quote_submissions)
NEXT_PUBLIC_SUPABASE_URL=https://tzxaewbadjursnhsokmg.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_DPG1wxg-sCedbvZdxvSGAQ_hTj9q2m6

# Resend (transactional email for quote-request notifications)
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx

# Address that receives quote-request notifications
QUOTE_RECIPIENT_EMAIL=mymechanicqld@gmail.com

# From-address for outbound transactional email.
# IMPORTANT: until you verify the mymechanicqld.com.au domain at
# https://resend.com/domains, sends will FAIL with anything other than
# `onboarding@resend.dev`. Use the verified address once DNS is set up.
QUOTE_SENDER_EMAIL=onboarding@resend.dev
# QUOTE_SENDER_EMAIL=contact@mymechanicqld.com.au   # ← use after domain verified

# Google Analytics 4 — Measurement ID from analytics.google.com
# Admin → Data Streams → Web → Measurement ID (starts with G-)
# Already hard-coded as a fallback in app/layout.tsx so the tag fires
# in production even if this var is empty. Setting it here just removes
# the hard-coded value from the picture.
NEXT_PUBLIC_GA_ID=G-6YSECEQTDG

# Google Search Console — value of the meta-tag verification (just the
# content="..." string, not the full tag).
NEXT_PUBLIC_GSC_VERIFICATION=
